{
  "name": "@philiprehberger/memo-ts",
  "version": "0.1.1",
  "description": "Advanced memoization with TTL, LRU, and WeakMap support",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": { "tsup": "^8.0.0", "typescript": "^5.0.0" },
  "keywords": ["memo", "memoize", "cache", "lru", "ttl", "weakmap", "performance"],
  "license": "MIT",
  "repository": { "type": "git", "url": "git+https://github.com/philiprehberger/ts-memo.git" },
  "homepage": "https://github.com/philiprehberger/ts-memo#readme",
  "bugs": { "url": "https://github.com/philiprehberger/ts-memo/issues" },
  "author": "Philip Rehberger",
  "engines": { "node": ">=18.0.0" },
  "sideEffects": false
}
